{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "marketing": {
      "packageName": "@mfe-storefront/marketing",
      "development": {
        "fallback": "http://localhost:3000",
        "local": 3000
      }
    },
    "docs": {
      "packageName": "@mfe-storefront/docs",
      "routing": [
        {
          "paths": ["/docs", "/docs/:path*"]
        }
      ],
      "development": {
        "local": 3001
      }
    },
    "dashboard": {
      "packageName": "@mfe-storefront/dashboard",
      "routing": [
        {
          "paths": ["/app", "/app/:path*", "/settings", "/settings/:path*"]
        }
      ],
      "development": {
        "local": 3002
      }
    }
  }
}